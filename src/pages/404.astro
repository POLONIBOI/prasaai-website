---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
---

<BaseLayout
  title="Page not found — PRASA ai"
  description="This page doesn't exist. Head back to the homepage or message us on WhatsApp."
>
  <main>
    <section class="error-page">
      <div class="container">
        <div class="error-lines" aria-hidden="true">
          <div class="error-line" style="background: var(--line-red);"></div>
          <div class="error-line" style="background: var(--line-green);"></div>
          <div class="error-line" style="background: var(--line-orange);"></div>
          <div class="error-line" style="background: var(--line-blue);"></div>
        </div>
        <h1>404</h1>
        <p class="error-title">This platform is empty.</p>
        <p class="error-sub">Looks like this train doesn't stop here. Let's get you back on track.</p>
        <div class="error-actions">
          <a href="/" class="btn-primary">Back to homepage</a>
          <WhatsAppCTA variant="secondary" text="Message us on WhatsApp" />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .error-page {
    padding: 160px 0 120px;
    text-align: center;
    background: var(--gradient-hero);
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .error-lines {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 40px;
  }

  .error-line {
    width: 48px;
    height: 4px;
    border-radius: 2px;
    opacity: 0.6;
  }

  .error-page h1 {
    font-size: clamp(5rem, 15vw, 10rem);
    font-weight: 800;
    color: var(--amber);
    line-height: 1;
    margin-bottom: 16px;
    letter-spacing: -0.04em;
    opacity: 0.8;
  }

  .error-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
  }

  .error-sub {
    font-size: 1.05rem;
    color: var(--text-secondary);
    margin-bottom: 40px;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }

  .error-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--amber);
    color: var(--bg-primary);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 50px;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }

  .btn-primary:hover {
    background: var(--amber-hover);
    color: var(--bg-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-cta);
  }

  @media (min-width: 640px) {
    .error-actions { flex-direction: row; justify-content: center; }
  }
</style>
