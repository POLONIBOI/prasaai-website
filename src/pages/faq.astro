---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FaqItem from '../components/FaqItem.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import { site } from '../data/site';
import { faq } from '../data/faq';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};
---

<BaseLayout
  title="FAQ — PRASA ai"
  description="Frequently asked questions about PRASA ai — how it works, what languages it supports, data privacy, and more."
  canonical={`${site.url}/faq`}
  jsonLd={[jsonLd]}
>
  <main>
    <section class="faq-hero">
      <div class="container">
        <h1 data-animate>Frequently asked <em>questions</em></h1>
        <p class="faq-sub" data-animate data-delay="1">Everything you need to know about PRASA ai. Can't find your answer? <a href={`mailto:${site.email}`}>Get in touch</a>.</p>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="faq-section">
      <div class="container">
        <div class="faq-list">
          {faq.map((item, i) => (
            <FaqItem
              question={item.question}
              answer={item.answer}
              delay={(i % 5) + 1}
            />
          ))}
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="faq-section faq-cta-section">
      <div class="container">
        <div class="faq-cta-card" data-animate="scale-in">
          <SectionHeading centered>Still have questions?</SectionHeading>
          <p>The fastest way to get help is to ask the bot directly. Send "help" on WhatsApp and PRASA ai will show you everything it can do.</p>
          <WhatsAppCTA variant="primary" text="Ask on WhatsApp" />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .faq-hero {
    padding: 120px 0 60px;
    text-align: center;
    background: var(--gradient-hero);
  }

  .faq-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }

  .faq-hero em {
    font-style: normal;
    color: var(--amber);
  }

  .faq-sub {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .faq-section {
    padding: 80px 0;
    position: relative;
    overflow: hidden;
  }

  .faq-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(37, 211, 102, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .faq-cta-card {
    max-width: 560px;
    margin: 0 auto;
    background: var(--bg-card);
    border-radius: 16px;
    padding: 48px 36px;
    border: 1px solid var(--border-subtle);
    text-align: center;
  }

  .faq-cta-card p {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 28px;
  }

  @media (max-width: 640px) {
    .faq-hero { padding: 100px 0 48px; }
    .faq-section { padding: 48px 0; }
    .faq-cta-card { padding: 32px 20px; }
  }
</style>
