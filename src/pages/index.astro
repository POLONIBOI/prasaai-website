---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureCard from '../components/FeatureCard.astro';
import BentoGrid from '../components/BentoGrid.astro';
import StepCard from '../components/StepCard.astro';
import WhatsAppMockup from '../components/WhatsAppMockup.astro';
import HeroScene from '../components/HeroScene.astro';
import { site } from '../data/site';
import { features } from '../data/features';
import { channels } from '../data/channels';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "PRASA ai",
    "url": site.url,
    "logo": `${site.url}/favicon.svg`,
    "description": "AI-powered WhatsApp assistant for Cape Town Metrorail commuters",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+27-76-054-6767",
      "contactType": "customer service",
      "availableLanguage": ["English", "Afrikaans", "isiXhosa"]
    },
    "sameAs": ["https://wa.me/27760546767"]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "PRASA ai",
    "url": site.url
  }
];
---

<BaseLayout
  title="PRASA ai — Your Cape Town Train Assistant on WhatsApp"
  description={site.description}
  canonical={`${site.url}/`}
  jsonLd={jsonLd}
>
  <main>

    <!-- HERO -->
    <section class="hero">
      <!-- Floating particles -->
      <div class="particle p1" aria-hidden="true"></div>
      <div class="particle p2" aria-hidden="true"></div>
      <div class="particle p3" aria-hidden="true"></div>
      <div class="particle p4" aria-hidden="true"></div>
      <div class="particle p5" aria-hidden="true"></div>
      <div class="particle p6" aria-hidden="true"></div>

      <div class="container">
        <div class="hero-layout">
          <div class="hero-text">
            <div class="hero-lines">
              <div class="hero-line" style="background: var(--line-red);"></div>
              <div class="hero-line" style="background: var(--line-green);"></div>
              <div class="hero-line" style="background: var(--line-orange);"></div>
              <div class="hero-line" style="background: var(--line-blue);"></div>
            </div>
            <h1 data-animate data-delay="1">Your Cape Town train assistant. <em>On WhatsApp.</em></h1>
            <p class="hero-sub" data-animate data-delay="2">Real-time schedules, delay alerts, and crowd reports — powered by AI, built by a commuter who gets it.</p>
            <div data-animate data-delay="3">
              <WhatsAppCTA variant="primary" />
            </div>
            <p class="hero-note" data-animate data-delay="4">Free &middot; No app download &middot; Works on any phone</p>
            <p class="hero-disclaimer" data-animate data-delay="5">Not an official PRASA service — yet.</p>
          </div>
          <div class="hero-visual">
            <HeroScene />
          </div>
        </div>
      </div>
    </section>

    <!-- THE PROBLEM -->
    <div class="section-divider"></div>
    <section class="section section-problem">
      <div class="container">
        <div class="prose">
          <SectionHeading>You know the feeling.</SectionHeading>
          <p class="prose-quote" data-animate>It's 6:47am. You're standing on the platform. No train. No announcement. You check the time again. Is it 5 minutes late or cancelled? Nobody around you knows either.</p>

          <!-- Stat strip -->
          <div class="stat-strip" data-animate data-delay="1">
            <div class="stat-card">
              <span class="stat-number" data-count="150000" data-suffix="+">0</span>
              <span class="stat-label">Daily Riders</span>
            </div>
            <div class="stat-card">
              <span class="stat-number" data-count="800" data-prefix="R">0</span>
              <span class="stat-label">Saved vs Taxis / Month</span>
            </div>
            <div class="stat-card">
              <span class="stat-number" data-count="2">0</span>
              <span class="stat-label">Stations with Screens</span>
            </div>
          </div>

          <p data-animate data-delay="2">Cape Town Metrorail has been getting genuinely better. The new X'Trapolis Mega trains are safer and more reliable. The City approved a Rail Business Plan in December 2025. But the information layer hasn't kept pace — when disruptions hit, commuters still find out by standing on an empty platform. Meanwhile, commuters across the network have built informal WhatsApp groups to share sightings and delays in real time.</p>
          <p class="prose-punch" data-animate data-delay="3">The trains are getting better. The information should too.</p>
        </div>
      </div>
    </section>

    <!-- FEATURES (BENTO GRID) -->
    <div class="section-divider"></div>
    <section class="section section-features">
      <div class="container">
        <SectionHeading centered>What it does</SectionHeading>
        <BentoGrid>
          {features.map((f, i) => (
            <FeatureCard
              emoji={f.emoji}
              icon={f.icon}
              title={f.title}
              description={f.description}
              span={f.span}
              delay={i + 1}
            />
          ))}
        </BentoGrid>
        <p class="features-note" data-animate>Built independently using publicly available PRASA schedule data.</p>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <div class="section-divider"></div>
    <section class="section section-howitworks">
      <div class="container">
        <SectionHeading centered>How it works</SectionHeading>
        <div class="steps-grid">
          <StepCard num={1} emoji="\u{1F4AC}" title="Message us on WhatsApp" description="Save +27 76 054 6767 or tap the button below." delay={1} />
          <div class="step-connector" aria-hidden="true">
            <svg class="step-connector-svg" viewBox="0 0 40 4" xmlns="http://www.w3.org/2000/svg">
              <line x1="0" y1="2" x2="40" y2="2" stroke="var(--amber-border)" stroke-width="2" stroke-dasharray="4 4"/>
              <circle class="step-connector-dot" r="3" fill="var(--amber)" cy="2">
                <animate attributeName="cx" values="0;40;0" dur="3s" repeatCount="indefinite" calcMode="spline" keySplines="0.42 0 0.58 1;0.42 0 0.58 1"/>
              </circle>
            </svg>
          </div>
          <StepCard num={2} emoji="\u{1F5E3}\uFE0F" title="Ask anything" description='"next train Retreat to Cape Town" or just "?" for your saved route.' delay={2} />
          <div class="step-connector" aria-hidden="true">
            <svg class="step-connector-svg" viewBox="0 0 40 4" xmlns="http://www.w3.org/2000/svg">
              <line x1="0" y1="2" x2="40" y2="2" stroke="var(--amber-border)" stroke-width="2" stroke-dasharray="4 4"/>
              <circle class="step-connector-dot" r="3" fill="var(--amber)" cy="2">
                <animate attributeName="cx" values="0;40;0" dur="3s" repeatCount="indefinite" calcMode="spline" keySplines="0.42 0 0.58 1;0.42 0 0.58 1"/>
              </circle>
            </svg>
          </div>
          <StepCard num={3} emoji="\u26A1" title="Get answers in seconds" description="Timetables, fares, maps, alerts — all in your chat." delay={3} />
        </div>

        <WhatsAppMockup />

        <div class="cta-center">
          <WhatsAppCTA variant="secondary" text="Try it now on WhatsApp" />
        </div>
      </div>
    </section>

    <!-- BUILT BY A COMMUTER -->
    <div class="section-divider"></div>
    <section class="section section-story story-section">
      <div class="container">
        <div class="prose">
          <SectionHeading>Built by a commuter. For commuters.</SectionHeading>
          <p data-animate>I ride the train every day. Every morning I'd stand on the platform wondering if my train was coming, delayed, or cancelled — scrolling Twitter for updates that came 30 minutes too late, asking in WhatsApp groups where someone three stations away might know something. Most mornings, I'd just guess.</p>
          <p data-animate data-delay="1">So I built what I wished existed. A WhatsApp bot that knows the full Metrorail timetable, checks for disruptions in real-time, and understands when you type "muizi to town." PRASA ai is not affiliated with PRASA — not yet. We're an independent project built by commuters, for commuters, with one goal: to prove that better passenger communication isn't just possible, it's overdue.</p>
        </div>
      </div>
    </section>

    <!-- WHATSAPP CHANNELS -->
    <div class="section-divider"></div>
    <section class="section section-channels">
      <div class="container">
        <SectionHeading centered>Follow your line</SectionHeading>
        <p class="channels-subtitle" data-animate>Get real-time updates from PRASA's official WhatsApp channels.</p>
        <div class="channels-grid">
          {channels.map((ch, i) => (
            <a
              href={ch.url}
              target="_blank"
              rel="noopener noreferrer"
              class="channel-card"
              style={`--channel-color: var(${ch.colorVar})`}
              data-animate
              data-delay={i + 1}
            >
              <span class="channel-name">{ch.name}</span>
              <span class="channel-follow">
                <svg class="channel-wa-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Follow
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- OPEN INVITATION -->
    <div class="section-divider"></div>
    <section class="section">
      <div class="container">
        <div class="invitation-card" data-animate="scale-in">
          <SectionHeading centered>To PRASA: Let's talk.</SectionHeading>
          <p>We built PRASA ai because we believe South Africa's commuters deserve world-class passenger information. We've done the hard work — real-time timetables, AI-powered assistance, crowd-sourced reporting, multilingual support. All on WhatsApp, where your passengers already are.</p>
          <p>This could be so much bigger as an official service. If anyone at PRASA, Metrorail, or the City of Cape Town wants to explore what that looks like — we're ready.</p>
          <a href={`mailto:${site.email}`} class="btn-outline">Get in touch</a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    padding: 100px 0 60px;
    background: var(--gradient-hero);
    text-align: center;
    overflow: hidden;
  }

  .hero-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-lines {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 32px;
  }

  .hero-line {
    height: 4px;
    border-radius: 2px;
  }

  .hero h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .hero h1 em {
    font-style: normal;
    color: var(--amber);
    background: linear-gradient(90deg, var(--amber) 0%, #FFE580 45%, var(--amber) 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: text-shimmer 3s ease-in-out infinite;
  }

  @keyframes text-shimmer {
    0% { background-position: 200% 50%; }
    100% { background-position: -200% 50%; }
  }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto 36px;
    line-height: 1.5;
  }

  .hero-note {
    margin-top: 20px;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .hero-disclaimer {
    margin-top: 12px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    opacity: 0.7;
    font-style: italic;
  }

  /* Hero visual — visible on mobile too */
  .hero-visual {
    max-width: 220px;
    margin: 24px auto 0;
    opacity: 0.6;
  }

  /* Floating particles */
  .particle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .p1 { width: 4px; height: 4px; background: var(--amber); top: 15%; left: 10%; animation: float-particle-1 10s ease-in-out infinite; }
  .p2 { width: 3px; height: 3px; background: var(--line-red); top: 25%; right: 15%; animation: float-particle-2 12s ease-in-out infinite; }
  .p3 { width: 5px; height: 5px; background: var(--amber); bottom: 30%; left: 20%; animation: float-particle-3 8s ease-in-out infinite; }
  .p4 { width: 3px; height: 3px; background: var(--line-blue); top: 40%; right: 25%; animation: float-particle-4 14s ease-in-out infinite; }
  .p5 { width: 6px; height: 6px; background: var(--amber); bottom: 20%; right: 10%; animation: float-particle-5 16s ease-in-out infinite; }
  .p6 { width: 4px; height: 4px; background: var(--line-green); top: 60%; left: 8%; animation: float-particle-6 11s ease-in-out infinite; }

  @media (min-width: 1024px) {
    .hero {
      padding: 140px 0 100px;
      text-align: left;
    }

    .hero-layout {
      flex-direction: row;
      align-items: center;
      gap: 60px;
    }

    .hero-text {
      flex: 1;
    }

    .hero-visual {
      display: block;
      flex: 0 0 400px;
      max-width: 400px;
      opacity: 1;
      margin: 0;
    }

    .hero-lines {
      justify-content: flex-start;
    }

    .hero-sub {
      margin-left: 0;
    }
  }

  /* SECTIONS */
  .section {
    padding: 80px 0;
    position: relative;
    overflow: hidden;
  }

  /* Section background gradients */
  .section-problem::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 0% 0%, rgba(255, 68, 68, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .section-features::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(94, 155, 255, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .section-howitworks::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 100% 100%, rgba(56, 181, 74, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .section-story::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(255, 154, 48, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .prose {
    max-width: 720px;
    margin: 0 auto;
  }

  .prose p {
    margin-bottom: 24px;
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .prose-quote {
    font-size: 1.1rem;
    color: var(--text-primary) !important;
    font-style: italic;
    border-left: 3px solid var(--amber);
    padding-left: 20px;
  }

  .prose-punch {
    color: var(--amber) !important;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 1.15rem !important;
    font-style: normal;
  }

  /* STAT STRIP */
  .stat-strip {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin: 32px 0;
  }

  .stat-card {
    background: var(--bg-card);
    border-radius: 12px;
    padding: 24px 20px;
    text-align: center;
    border: 1px solid var(--border-subtle);
  }

  .stat-number {
    display: block;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 2rem;
    color: var(--amber);
    line-height: 1.2;
    margin-bottom: 4px;
  }

  .stat-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    font-weight: 600;
  }

  @media (min-width: 640px) {
    .stat-strip {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* STORY */
  .story-section {
    position: relative;
  }

  /* FEATURES NOTE */
  .features-note {
    text-align: center;
    margin-top: 32px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    opacity: 0.7;
  }

  /* STEPS */
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    margin-top: 40px;
    margin-bottom: 48px;
  }

  .step-connector {
    display: none;
  }

  .step-connector-svg {
    width: 40px;
    height: 4px;
  }

  @media (min-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr auto 1fr auto 1fr;
      align-items: center;
    }

    .step-connector {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }

  .cta-center {
    text-align: center;
  }

  /* INVITATION — enhanced */
  .invitation-card {
    max-width: 640px;
    margin: 0 auto;
    background: var(--bg-card);
    border-radius: 16px;
    padding: 48px 36px;
    border: 1px solid rgba(255, 192, 64, 0.3);
    text-align: center;
    box-shadow: 0 0 60px rgba(255, 192, 64, 0.08), inset 0 1px 0 rgba(255, 192, 64, 0.1);
  }

  .invitation-card p {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 2px solid var(--amber);
    color: var(--amber);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 50px;
    transition: background 0.2s, color 0.2s;
  }

  .btn-outline:hover {
    background: var(--amber);
    color: var(--bg-primary);
  }

  @media (max-width: 640px) {
    .hero { padding: 100px 0 48px; }
    .section { padding: 48px 0; }
    .invitation-card { padding: 32px 20px; }
  }

  /* WHATSAPP CHANNELS */
  .section-channels::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(37, 211, 102, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .channels-subtitle {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: 36px;
  }

  .channels-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    max-width: 720px;
    margin: 0 auto;
  }

  .channel-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-card);
    border-radius: 12px;
    padding: 16px 20px;
    border: 1px solid var(--border-subtle);
    border-left: 3px solid var(--channel-color);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .channel-card:hover {
    border-color: var(--channel-color);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .channel-name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .channel-follow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--wa-green);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .channel-wa-icon {
    width: 16px;
    height: 16px;
  }

  @media (min-width: 640px) {
    .channels-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .channels-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero h1 em {
      background: none;
      -webkit-background-clip: unset;
      -webkit-text-fill-color: var(--amber);
      animation: none;
    }

    .particle {
      display: none;
    }
  }
</style>
