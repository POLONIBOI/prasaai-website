---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import TutorialChat from '../components/TutorialChat.astro';
import { tutorials } from '../data/tutorials';
import { site } from '../data/site';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to use PRASA ai on WhatsApp",
  "description": "Step-by-step tutorials for every PRASA ai feature — train times, fares, alerts, and more.",
  "step": tutorials.map((t, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "name": t.title,
    "text": t.description,
  })),
};
---

<BaseLayout
  title="Tutorials — How to Use PRASA ai on WhatsApp"
  description="Learn how to use every PRASA ai feature — train times, fares, saved commutes, crowd reports, multilingual support, and more."
  canonical={`${site.url}/tutorials`}
  jsonLd={[jsonLd]}
>
  <main>
    <section class="section section-tutorials-hero">
      <div class="container">
        <SectionHeading centered>How to use PRASA ai</SectionHeading>
        <p class="tutorials-subtitle" data-animate>
          Every feature explained with real chat examples. Just message us on WhatsApp and try it yourself.
        </p>
      </div>
    </section>

    <section class="section section-tutorials">
      <div class="container">
        <div class="tutorials-grid">
          {tutorials.map((tutorial, i) => (
            <TutorialChat tutorial={tutorial} index={i} />
          ))}
        </div>

        <div class="cta-center" data-animate>
          <p class="tutorials-cta-text">Ready to try it?</p>
          <WhatsAppCTA variant="secondary" text="Message PRASA ai now" />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .section-tutorials-hero {
    padding: 120px 0 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .section-tutorials-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(255, 192, 64, 0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .tutorials-subtitle {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .section-tutorials {
    padding: 20px 0 80px;
  }

  .tutorials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 960px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .tutorials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .tutorials-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .cta-center {
    text-align: center;
    margin-top: 56px;
  }

  .tutorials-cta-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--text-primary);
    margin-bottom: 20px;
  }

  @media (max-width: 640px) {
    .section-tutorials-hero {
      padding: 100px 0 24px;
    }

    .section-tutorials {
      padding: 16px 0 48px;
    }
  }
</style>
