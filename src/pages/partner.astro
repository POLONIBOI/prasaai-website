---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="Partner with PRASA ai — For PRASA, Metrorail & Government"
  description="Explore how an official partnership with PRASA ai can transform passenger communication across South Africa's rail network."
  canonical={`${site.url}/partner`}
>
  <main>
    <section class="partner-hero">
      <div class="container">
        <h1 data-animate>Let's build this <em>together</em></h1>
        <p class="partner-sub" data-animate data-delay="1">PRASA ai is ready to become the official passenger information layer for South Africa's rail network. Here's what that could look like.</p>
      </div>
    </section>

    <!-- What we've built -->
    <div class="section-divider"></div>
    <section class="partner-section section-built">
      <div class="container">
        <SectionHeading>What PRASA ai already does</SectionHeading>
        <div class="capability-grid">
          <div class="capability-card" data-animate data-delay="1">
            <span class="capability-icon" aria-hidden="true">&#x1F4CB;</span>
            <h3>Full Timetable Access</h3>
            <!-- PLACEHOLDER -->
            <p>101 stations, 19 routes, 556 daily trips — all searchable via natural language on WhatsApp.</p>
          </div>
          <div class="capability-card" data-animate data-delay="2">
            <span class="capability-icon" aria-hidden="true">&#x1F5E3;&#xFE0F;</span>
            <h3>Multilingual AI</h3>
            <p>Understands English, Afrikaans, and isiXhosa. Handles slang, abbreviations, and typos gracefully.</p>
          </div>
          <div class="capability-card" data-animate data-delay="3">
            <span class="capability-icon" aria-hidden="true">&#x26A1;</span>
            <h3>Crowd-sourced Alerts</h3>
            <p>Real-time delay and disruption reports from commuters across 5 WhatsApp channels.</p>
          </div>
          <div class="capability-card" data-animate data-delay="4">
            <span class="capability-icon" aria-hidden="true">&#x1F4B0;</span>
            <h3>Fare Information</h3>
            <p>Trip costs, weekly vs monthly ticket comparisons, and MetroPlus pricing — all instant.</p>
          </div>
          <div class="capability-card" data-animate data-delay="5">
            <span class="capability-icon" aria-hidden="true">&#x1F4F1;</span>
            <h3>Zero Friction</h3>
            <p>No app download required. Works on any phone with WhatsApp — reaching the widest possible audience.</p>
          </div>
          <div class="capability-card" data-animate data-delay="1">
            <span class="capability-icon" aria-hidden="true">&#x1F512;</span>
            <h3>POPIA Compliant</h3>
            <p>Minimal data collection, user-controlled deletion, transparent privacy policy. Built for trust.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- What partnership unlocks -->
    <div class="section-divider"></div>
    <section class="partner-section section-unlocks">
      <div class="container">
        <SectionHeading>What an official partnership unlocks</SectionHeading>
        <div class="prose">
          <p data-animate>PRASA ai already works well with public data. With official access and endorsement, it becomes transformative.</p>
        </div>
        <div class="unlock-grid">
          <div class="unlock-card" data-animate data-delay="1">
            <div class="unlock-header">
              <span class="unlock-icon" aria-hidden="true">&#x1F4E1;</span>
              <h3>Real-time GPS Data</h3>
            </div>
            <p>Live train positions on a map. "Where is my train right now?" becomes answerable.</p>
          </div>
          <div class="unlock-card" data-animate data-delay="2">
            <div class="unlock-header">
              <span class="unlock-icon" aria-hidden="true">&#x1F514;</span>
              <h3>Push Notifications</h3>
            </div>
            <p>Proactive alerts before commuters leave home: "Your 07:15 from Retreat is running 12 minutes late."</p>
          </div>
          <div class="unlock-card" data-animate data-delay="3">
            <div class="unlock-header">
              <span class="unlock-icon" aria-hidden="true">&#x2705;</span>
              <h3>Official Branding</h3>
            </div>
            <p>Verified WhatsApp Business account with PRASA branding. Commuter trust goes from curious to confident.</p>
          </div>
          <div class="unlock-card" data-animate data-delay="4">
            <div class="unlock-header">
              <span class="unlock-icon" aria-hidden="true">&#x1F4CA;</span>
              <h3>Analytics Dashboard</h3>
            </div>
            <p>Understand what commuters ask most, which routes need attention, and measure NPS in real time.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Integration options -->
    <div class="section-divider"></div>
    <section class="partner-section section-integration">
      <div class="container">
        <SectionHeading>Integration options</SectionHeading>
        <div class="integration-grid">
          <div class="integration-card" data-animate data-delay="1">
            <h3>API Integration</h3>
            <p>Connect PRASA ai to existing systems. Feed real-time data in, get passenger insights out.</p>
          </div>
          <div class="integration-card" data-animate data-delay="2">
            <h3>White-label Solution</h3>
            <p>Deploy as PRASA's own branded service — powered by our technology, wearing your colours.</p>
          </div>
          <div class="integration-card" data-animate data-delay="3">
            <h3>Co-branded Partnership</h3>
            <p>Keep the PRASA ai brand commuters already know. Add official endorsement and data access.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Expected outcomes -->
    <div class="section-divider"></div>
    <section class="partner-section section-outcomes">
      <div class="container">
        <SectionHeading centered>Expected outcomes</SectionHeading>
        <div class="outcomes-grid">
          <div class="outcome-card" data-animate data-delay="1">
            <span class="outcome-number" aria-hidden="true">&#x1F4C9;</span>
            <h3>Reduced call centre volume</h3>
            <p>Commuters get instant answers on WhatsApp instead of calling or queuing.</p>
          </div>
          <div class="outcome-card" data-animate data-delay="2">
            <span class="outcome-number" aria-hidden="true">&#x1F604;</span>
            <h3>Happier commuters</h3>
            <p>Information reduces anxiety. Knowing your train is 10 minutes late is better than not knowing at all.</p>
          </div>
          <div class="outcome-card" data-animate data-delay="3">
            <span class="outcome-number" aria-hidden="true">&#x1F4C8;</span>
            <h3>Measurable NPS improvement</h3>
            <p>Track satisfaction in real time. Every interaction is a data point.</p>
          </div>
          <div class="outcome-card" data-animate data-delay="4">
            <span class="outcome-number" aria-hidden="true">&#x1F30D;</span>
            <h3>Scalable to all regions</h3>
            <p>The same system can expand to Gauteng, KZN, and beyond — no new apps, no new infrastructure.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="section-divider"></div>
    <section class="partner-section">
      <div class="container">
        <div class="partner-cta-card" data-animate="scale-in">
          <SectionHeading centered>Ready to explore?</SectionHeading>
          <p>Whether you're at PRASA, Metrorail, the City of Cape Town, or another transport authority — we'd love to have a conversation about what this could become.</p>
          <div class="partner-cta-actions">
            <a href={`mailto:${site.email}?subject=Partnership%20Inquiry%20—%20PRASA%20ai`} class="btn-primary">Start a conversation</a>
            <a href="/contact" class="btn-outline">Contact details</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .partner-hero {
    padding: 120px 0 60px;
    text-align: center;
    background: var(--gradient-hero);
  }

  .partner-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }

  .partner-hero em {
    font-style: normal;
    color: var(--amber);
  }

  .partner-sub {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .partner-section {
    padding: 80px 0;
    position: relative;
    overflow: hidden;
  }

  .prose {
    max-width: 720px;
    margin: 0 auto 40px;
  }

  .prose p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  /* Section backgrounds */
  .section-built::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 0% 0%, rgba(94, 155, 255, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .section-unlocks::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 100% 0%, rgba(56, 181, 74, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .section-outcomes::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(255, 154, 48, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Capability grid */
  .capability-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 40px;
  }

  .capability-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 24px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .capability-card:hover {
    border-color: var(--amber-border);
    transform: translateY(-2px);
  }

  .capability-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 12px;
  }

  .capability-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text-primary);
  }

  .capability-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* Unlock grid */
  .unlock-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 720px;
    margin: 0 auto;
  }

  .unlock-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 24px;
    border-left: 3px solid var(--amber);
  }

  .unlock-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .unlock-icon {
    font-size: 1.25rem;
  }

  .unlock-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .unlock-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* Integration grid */
  .integration-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 40px;
  }

  .integration-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 32px 24px;
    text-align: center;
    transition: border-color 0.2s, transform 0.2s;
  }

  .integration-card:hover {
    border-color: var(--amber-border);
    transform: translateY(-2px);
  }

  .integration-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--amber);
    margin-bottom: 12px;
  }

  .integration-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* Outcomes grid */
  .outcomes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 800px;
    margin: 40px auto 0;
  }

  .outcome-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
  }

  .outcome-number {
    font-size: 2rem;
    display: block;
    margin-bottom: 12px;
  }

  .outcome-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .outcome-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* CTA card */
  .partner-cta-card {
    max-width: 640px;
    margin: 0 auto;
    background: var(--bg-card);
    border-radius: 16px;
    padding: 48px 36px;
    border: 1px solid rgba(255, 192, 64, 0.3);
    text-align: center;
    box-shadow: 0 0 60px rgba(255, 192, 64, 0.08), inset 0 1px 0 rgba(255, 192, 64, 0.1);
  }

  .partner-cta-card p {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .partner-cta-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--amber);
    color: var(--bg-primary);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 50px;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }

  .btn-primary:hover {
    background: var(--amber-hover);
    color: var(--bg-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-cta);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 2px solid var(--amber);
    color: var(--amber);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 50px;
    transition: background 0.2s, color 0.2s;
    text-decoration: none;
  }

  .btn-outline:hover {
    background: var(--amber);
    color: var(--bg-primary);
  }

  /* Responsive grids */
  @media (min-width: 640px) {
    .capability-grid { grid-template-columns: repeat(2, 1fr); }
    .outcomes-grid { grid-template-columns: repeat(2, 1fr); }
    .partner-cta-actions { flex-direction: row; justify-content: center; }
  }

  @media (min-width: 768px) {
    .capability-grid { grid-template-columns: repeat(3, 1fr); }
    .integration-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 640px) {
    .partner-hero { padding: 100px 0 48px; }
    .partner-section { padding: 48px 0; }
    .partner-cta-card { padding: 32px 20px; }
  }
</style>
