---
import SEO from '../components/SEO.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import '../styles/typography.css';
import '../styles/global.css';
import '../styles/animations.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  showPageLinks?: boolean;
  jsonLd?: object[];
}

const { title, description, canonical, showPageLinks = true, jsonLd = [] } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SEO title={title} description={description} canonical={canonical} />
  {jsonLd.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body>
  <Nav showPageLinks={showPageLinks} />
  <slot />
  <Footer />
  <FloatingWhatsApp />
  <script src="../scripts/scroll-animations.ts"></script>
</body>
</html>
