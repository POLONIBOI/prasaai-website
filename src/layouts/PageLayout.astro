---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  subtitle?: string;
}

const { title, description, canonical, subtitle } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <main>
    <header class="page-hero">
      <div class="container">
        <h1>{title.split(' — ')[0]}</h1>
        {subtitle && <p class="page-subtitle">{subtitle}</p>}
      </div>
    </header>
    <div class="page-content">
      <div class="container">
        <div class="page-inner">
          <slot />
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .page-hero {
    padding: 120px 0 40px;
    text-align: center;
    background: var(--gradient-hero);
  }

  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }

  .page-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .page-content {
    padding-bottom: 80px;
  }

  .page-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .page-hero {
      padding: 100px 0 32px;
    }

    .page-content {
      padding-bottom: 60px;
    }
  }
</style>
