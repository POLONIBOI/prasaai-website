---
import { site } from '../data/site';
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-info">
        <div class="footer-brand">PRASA <span>ai</span></div>
        <p class="footer-contact">
          <a href={`mailto:${site.email}`}>{site.email}</a> &middot; <a href="tel:+27760546767">{site.whatsappNumber}</a>
        </p>
      </div>
      <div class="footer-nav">
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Service</a>
        </div>
        <div class="footer-social">
          <a href="https://wa.me/27760546767" target="_blank" rel="noopener">WhatsApp</a>
          <a href="#" target="_blank" rel="noopener">Instagram</a>
          <a href="#" target="_blank" rel="noopener">Facebook</a>
        </div>
      </div>
    </div>

    <div class="footer-disclaimer">
      PRASA ai is an independent project by {site.agencyName}. We are not affiliated with, endorsed by, or connected to the Passenger Rail Agency of South Africa (PRASA), Metrorail, or any government entity. Train schedule data is sourced from publicly available GTFS feeds. We aspire to partner with PRASA officially — until then, we're just commuters building what we wish existed.
    </div>

    <div class="footer-bottom">
      <p class="footer-love">Built with &#10084;&#65039; in Cape Town by {site.agencyName}</p>
      <p class="footer-copy">&copy; 2026 {site.agencyName}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-subtle);
    background: var(--bg-card);
    padding: 48px 0 32px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    margin-bottom: 32px;
  }

  .footer-brand {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .footer-brand span { color: var(--amber); }

  .footer-contact {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 4px;
  }

  .footer-contact a {
    color: var(--text-secondary);
  }

  .footer-contact a:hover {
    color: var(--amber);
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    margin-bottom: 20px;
  }

  .footer-links a {
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .footer-links a:hover { color: var(--amber); }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 0.875rem;
  }

  .footer-social a {
    color: var(--text-secondary);
  }

  .footer-social a:hover { color: var(--amber); }

  .footer-disclaimer {
    background: rgba(245, 166, 35, 0.04);
    border: 1px solid rgba(245, 166, 35, 0.1);
    border-radius: 12px;
    padding: 20px 24px;
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .footer-bottom {
    text-align: center;
  }

  .footer-love {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-bottom: 4px;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr;
    }
  }
</style>
