---
interface Props {
  name: string;
  role: string;
  bio: string;
}

const { name, role, bio } = Astro.props;
const initial = name.charAt(0);
---

<div class="team-card" data-animate>
  <div class="team-avatar">{initial}</div>
  <h3>{name}</h3>
  <p class="team-role">{role}</p>
  <p class="team-bio">{bio}</p>
</div>

<style>
  .team-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    transition: border-color 0.3s;
  }

  .team-card:hover {
    border-color: var(--border-amber);
  }

  .team-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--amber);
    color: var(--bg-primary);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .team-role {
    font-size: 0.875rem;
    color: var(--amber);
    font-weight: 600;
    margin-bottom: 12px;
  }

  .team-bio {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }
</style>
