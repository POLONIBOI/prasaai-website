---
import type { Tutorial } from '../data/tutorials';

interface Props {
  tutorial: Tutorial;
  index: number;
}

const { tutorial, index } = Astro.props;
---

<div class="tutorial-card" data-animate data-delay={Math.min(index % 3 + 1, 3).toString()}>
  <div class="tutorial-header">
    <span class="tutorial-emoji">{tutorial.emoji}</span>
    <div>
      <h3 class="tutorial-title">{tutorial.title}</h3>
      <p class="tutorial-desc">{tutorial.description}</p>
    </div>
  </div>

  <div class="wa-mockup-mini" data-animate-chat>
    <div class="wa-header-mini">
      <div class="wa-avatar-mini">P</div>
      <div>
        <div class="wa-name-mini">PRASA ai</div>
        <div class="wa-status-mini">online</div>
      </div>
    </div>
    <div class="wa-chat-mini">
      {tutorial.messages.map((msg) => (
        <div
          class={`wa-msg-mini ${msg.from === 'user' ? 'wa-msg-user-mini' : 'wa-msg-bot-mini'}`}
          data-chat-animate
        >
          {msg.lines.map((line) => (
            <span class="msg-line-mini">{line}</span>
          ))}
          <div class="wa-msg-time-mini">{msg.time}</div>
        </div>
      ))}
      <div class="typing-indicator-mini" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
    </div>
  </div>
</div>

<style>
  .tutorial-card {
    background: var(--bg-card);
    border-radius: 16px;
    border: 1px solid var(--border-subtle);
    padding: 24px;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
  }

  .tutorial-card:hover {
    border-color: var(--amber-border);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .tutorial-header {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-bottom: 20px;
  }

  .tutorial-emoji {
    font-size: 1.6rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .tutorial-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .tutorial-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* Mini WhatsApp mockup */
  .wa-mockup-mini {
    background: var(--wa-dark, #0B141A);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(151, 170, 192, 0.1);
  }

  .wa-header-mini {
    background: #1F2C34;
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .wa-avatar-mini {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--amber);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 0.7rem;
    color: var(--bg-primary);
  }

  .wa-name-mini {
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--text-primary);
  }

  .wa-status-mini {
    font-size: 0.65rem;
    color: var(--text-secondary);
  }

  .wa-chat-mini {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-height: 80px;
  }

  .wa-msg-mini {
    max-width: 88%;
    padding: 6px 10px;
    border-radius: 8px;
    font-size: 0.78rem;
    line-height: 1.4;
  }

  .wa-msg-user-mini {
    align-self: flex-end;
    background: var(--wa-bubble-user, #005C4B);
    border-bottom-right-radius: 2px;
    color: #F0F4F8;
  }

  .wa-msg-bot-mini {
    align-self: flex-start;
    background: var(--wa-bubble-bot, #1F2C34);
    border-bottom-left-radius: 2px;
    color: #F0F4F8;
  }

  .wa-msg-time-mini {
    font-size: 0.55rem;
    color: rgba(240, 244, 248, 0.4);
    text-align: right;
    margin-top: 3px;
  }

  .msg-line-mini {
    display: block;
    margin-bottom: 1px;
  }

  /* Typing indicator */
  .typing-indicator-mini {
    align-self: flex-start;
    background: var(--wa-bubble-bot, #1F2C34);
    border-radius: 8px;
    padding: 8px 14px;
    display: none;
    gap: 3px;
    align-items: center;
  }

  .typing-indicator-mini.is-active {
    display: flex;
  }

  .typing-indicator-mini span {
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--text-secondary);
    opacity: 0.6;
  }

  @media (prefers-reduced-motion: no-preference) {
    .typing-indicator-mini span:nth-child(1) { animation: typing-bounce-mini 1.2s 0s infinite; }
    .typing-indicator-mini span:nth-child(2) { animation: typing-bounce-mini 1.2s 0.15s infinite; }
    .typing-indicator-mini span:nth-child(3) { animation: typing-bounce-mini 1.2s 0.3s infinite; }

    @keyframes typing-bounce-mini {
      0%, 60%, 100% { transform: translateY(0); }
      30% { transform: translateY(-3px); }
    }

    /* Chat message reveal */
    .wa-msg-mini[data-chat-animate] {
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }

    .wa-msg-mini[data-chat-animate].chat-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-msg-mini[data-chat-animate] {
      opacity: 1 !important;
      transform: none !important;
    }

    .typing-indicator-mini {
      display: none !important;
    }
  }
</style>
