---
interface Props {
  num: number;
  emoji: string;
  title: string;
  description: string;
  delay?: number;
}

const { num, emoji, title, description, delay = 0 } = Astro.props;
---

<div class="step" data-animate data-delay={delay}>
  <span class="step-emoji">{emoji}</span>
  <span class="step-num">{num}</span>
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .step {
    text-align: center;
  }

  .step-emoji {
    font-size: 2.2rem;
    margin-bottom: 12px;
    display: block;
  }

  .step-num {
    display: inline-block;
    background: var(--amber);
    color: var(--bg-primary);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    width: 24px;
    height: 24px;
    line-height: 24px;
    border-radius: 50%;
    margin-bottom: 8px;
  }

  h3 {
    font-size: 1.05rem;
    margin-bottom: 6px;
  }

  p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }
</style>
